# ============================================================
# FACEBOOK / META
# ============================================================
# Lấy tại: Facebook Developer Dashboard > Messenger > Settings > Access Tokens
PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Chuỗi bí mật TỰ ĐẶT — dùng khi cấu hình webhook trên Facebook Developer Dashboard
VERIFY_TOKEN=lucky_cake_webhook_secret_2026

# Lấy tại: Facebook App Dashboard > Settings > Basic > App Secret
APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# GITHUB MODELS API (OpenAI-compatible, miễn phí)
# ============================================================
# Tạo tại: github.com > Settings > Developer Settings > Personal Access Tokens > Fine-grained
# Permission cần: Models > Read
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxx

# Model sử dụng (không cần đổi)
AI_MODEL=gpt-4o-mini
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com

# ============================================================
# GOOGLE SHEETS
# ============================================================
# Nội dung file JSON của Google Service Account (nén thành 1 dòng)
# Hướng dẫn: Google Cloud Console > IAM > Service Accounts > Create > Download JSON key
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ID của Google Spreadsheet (lấy từ URL: docs.google.com/spreadsheets/d/[ID]/edit)
GOOGLE_SHEET_ID=1BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxI

# ============================================================
# APP CONFIG
# ============================================================
MAX_HISTORY_MESSAGES=20
DATA_DIR=data
PORT=8000
